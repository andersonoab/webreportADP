Private Function PromptTipo(ByVal assunto As String, ByVal email As String) As String
    Dim msg As String, resp As String

    msg = "Selecione o TIPO (Tela 1)" & vbCrLf & vbCrLf & _
          "Remetente: " & email & vbCrLf & _
          "Assunto/Contexto: " & assunto & vbCrLf & vbCrLf & _
          "1 - BENEFICIOS" & vbCrLf & _
          "2 - NF" & vbCrLf & _
          "3 - FORNECEDORES" & vbCrLf & _
          "4 - FOLHA" & vbCrLf & _
          "5 - ENCARGOS" & vbCrLf & _
          "6 - PONTO" & vbCrLf & _
          "7 - OUTROS"

    resp = Trim$(CStr(InputBox(msg, "Mapeamento - Tipo")))

    Select Case resp
        Case "1": PromptTipo = "BENEFICIOS"
        Case "2": PromptTipo = "NF"
        Case "3": PromptTipo = "FORNECEDORES"
        Case "4": PromptTipo = "FOLHA"
        Case "5": PromptTipo = "ENCARGOS"
        Case "6": PromptTipo = "PONTO"
        Case Else: PromptTipo = "OUTROS"
    End Select
End Function

Private Function PromptFornecedor(ByVal assunto As String, ByVal email As String) As String
    Dim fornecedores As Variant
    fornecedores = GetListaFornecedores()

    Dim msg As String, i As Long, resp As String, idx As Long

    msg = "Selecione o FORNECEDOR (Tela 2)" & vbCrLf & vbCrLf & _
          "Remetente: " & email & vbCrLf & _
          "Assunto/Contexto: " & assunto & vbCrLf & vbCrLf

    For i = LBound(fornecedores) To UBound(fornecedores)
        msg = msg & (i + 1) & " - " & fornecedores(i) & vbCrLf
    Next i

    msg = msg & vbCrLf & "Digite o número. Se não estiver na lista, deixe em branco para digitar o nome."

    resp = Trim$(CStr(InputBox(msg, "Mapeamento - Fornecedor")))

    If resp = "" Then
        PromptFornecedor = Trim$(CStr(InputBox("Fornecedor não listado. Digite o nome:", "Fornecedor", "N/I")))
        Exit Function
    End If

    If IsNumeric(resp) Then
        idx = CLng(resp) - 1
        If idx >= LBound(fornecedores) And idx <= UBound(fornecedores) Then
            PromptFornecedor = CStr(fornecedores(idx))
        Else
            PromptFornecedor = Trim$(CStr(InputBox("Número inválido. Digite o nome:", "Fornecedor", "N/I")))
        End If
    Else
        PromptFornecedor = Trim$(CStr(InputBox("Entrada inválida. Digite o nome:", "Fornecedor", "N/I")))
    End If
End Function

