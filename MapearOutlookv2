Public Sub AtualizarGantt(ByVal wb As Object, ByVal wsChecklist As Object)
    On Error GoTo TrataErro

    Dim wsGantt As Object
    Set wsGantt = EnsureSheet(wb, GANTT_SHEET_NAME)

    MontarGantt_FromChecklist wsChecklist, wsGantt

    Exit Sub
TrataErro:
    Debug.Print "AtualizarGantt erro " & Err.Number & ": " & Err.Description
End Sub

Private Sub MontarGantt_FromChecklist(ByVal wsChecklist As Object, ByVal wsGantt As Object)
    On Error GoTo TrataErro

    Dim startWeek As Date, endWeek As Date
    startWeek = WeekStartMonday(Date)
    endWeek = DateAdd("d", (GANTT_WEEKS_TO_SHOW - 1) * 7, startWeek)

    Dim weeksCount As Long, lastColWanted As Long
    weeksCount = CLng((endWeek - startWeek) / 7) + 1
    lastColWanted = GANTT_FIRST_WEEK_COL + weeksCount - 1

    EnsureGanttLayout wsGantt, startWeek, endWeek, lastColWanted

    Dim lastRowChecklist As Long
    lastRowChecklist = wsChecklist.Cells(wsChecklist.Rows.Count, "A").End(-4162).Row

    If lastRowChecklist < 2 Then
        PrepararLayoutGanttVazio wsGantt, lastColWanted
        Exit Sub
    End If

    Dim dict As Object
    Set dict = CreateObject("Scripting.Dictionary")
    dict.CompareMode = vbTextCompare

    Dim lastRowGantt As Long
    lastRowGantt = wsGantt.Cells(wsGantt.Rows.Count, "A").End(-4162).Row
    If lastRowGantt < GANTT_FIRST_DATA_ROW Then lastRowGantt = GANTT_FIRST_DATA_ROW - 1

    Dim gr As Long
    For gr = GANTT_FIRST_DATA_ROW To lastRowGantt
        Dim existingKey As String
        existingKey = Trim$(CStr(wsGantt.Cells(gr, GANTT_TECH_COL_ENTRYID).Value))
        If existingKey <> "" Then
            If Not dict.Exists(existingKey) Then dict.Add existingKey, gr
        End If
    Next gr

    Dim r As Long, outRow As Long
    outRow = lastRowGantt

    For r = 2 To lastRowChecklist

        Dim fornecedor As String, tipo As String, criticidade As String, acao As String
        Dim vencISO As String, status As String, assunto As String
        Dim entryID As String

        fornecedor = CStr(wsChecklist.Cells(r, 2).Value)
        tipo = CStr(wsChecklist.Cells(r, 3).Value)
        criticidade = CStr(wsChecklist.Cells(r, 4).Value)
        acao = CStr(wsChecklist.Cells(r, 5).Value)
        vencISO = CStr(wsChecklist.Cells(r, 6).Value)
        status = CStr(wsChecklist.Cells(r, 7).Value)
        assunto = CStr(wsChecklist.Cells(r, 12).Value)
        entryID = Trim$(CStr(wsChecklist.Cells(r, 13).Value))

        If entryID = "" Then
            entryID = "SEMID|" & fornecedor & "|" & tipo & "|" & Left$(assunto, 80) & "|" & CStr(wsChecklist.Cells(r, 1).Value)
        End If

        Dim tgtRow As Long
        If dict.Exists(entryID) Then
            tgtRow = CLng(dict(entryID))
        Else
            outRow = outRow + 1
            tgtRow = outRow
            dict.Add entryID, tgtRow
        End If

        Dim dtIni As Date, dtFim As Date
        If Not TryParseISODate(wsChecklist.Cells(r, 8).Value, dtIni) Then dtIni = startWeek
        If Not TryParseISODate(wsChecklist.Cells(r, 9).Value, dtFim) Then
            If TryParseISODate(vencISO, dtFim) Then
                ' ok
            Else
                dtFim = DateAdd("d", 7, dtIni)
            End If
        End If
        If dtFim < dtIni Then dtFim = dtIni

        wsGantt.Cells(tgtRow, 1).Value = fornecedor
        wsGantt.Cells(tgtRow, 2).Value = tipo
        wsGantt.Cells(tgtRow, 3).Value = criticidade
        wsGantt.Cells(tgtRow, 4).Value = acao
        wsGantt.Cells(tgtRow, 5).Value = assunto

        Dim dtVenc As Date
        If TryParseISODate(vencISO, dtVenc) Then
            wsGantt.Cells(tgtRow, 6).NumberFormat = "dd/mm/yyyy"
            wsGantt.Cells(tgtRow, 6).Value = dtVenc
        Else
            wsGantt.Cells(tgtRow, 6).NumberFormat = "@"
            wsGantt.Cells(tgtRow, 6).Value = vencISO
        End If

        wsGantt.Cells(tgtRow, 7).Value = status

        wsGantt.Cells(tgtRow, GANTT_TECH_COL_ENTRYID).NumberFormat = "@"
        wsGantt.Cells(tgtRow, GANTT_TECH_COL_ENTRYID).Value = entryID

        ClearWeekCells wsGantt, tgtRow, GANTT_FIRST_WEEK_COL, lastColWanted
        PintarBarrasSemanais wsGantt, tgtRow, dtIni, dtFim, startWeek, endWeek, lastColWanted

    Next r

    If outRow < GANTT_FIRST_DATA_ROW Then outRow = GANTT_FIRST_DATA_ROW

    FinalizarGanttLayout wsGantt, outRow, lastColWanted

    Exit Sub

TrataErro:
    Debug.Print "MontarGantt_FromChecklist erro " & Err.Number & ": " & Err.Description
End Sub

Private Sub EnsureGanttLayout(ByVal ws As Object, ByVal startWeek As Date, ByVal endWeek As Date, ByVal lastColWanted As Long)

    ' Título
    ws.Range(ws.Cells(1, 1), ws.Cells(1, lastColWanted)).Merge
    ws.Cells(1, 1).Value = "GANTT - DP Triagem (por semana) - Janela atual"
    ws.Cells(1, 1).Font.Bold = True
    ws.Cells(1, 1).Font.Size = 14
    ws.Range(ws.Cells(1, 1), ws.Cells(1, lastColWanted)).Interior.Color = SonovaNavy()
    ws.Range(ws.Cells(1, 1), ws.Cells(1, lastColWanted)).Font.Color = vbWhite
    ws.Rows(1).RowHeight = 26

    ' Legenda (linha 2)
    ws.Cells(2, 1).Value = "Legenda:"
    ws.Cells(2, 1).Font.Bold = True

    ws.Cells(2, 2).Value = "Concluído"
    ws.Cells(2, 2).Interior.Color = SonovaGreen()
    ws.Cells(2, 2).Font.Color = vbWhite

    ws.Cells(2, 3).Value = "Pendente"
    ws.Cells(2, 3).Interior.Color = SonovaBlue()
    ws.Cells(2, 3).Font.Color = vbWhite

    ws.Cells(2, 4).Value = "Atrasado"
    ws.Cells(2, 4).Interior.Color = SonovaRed()
    ws.Cells(2, 4).Font.Color = vbWhite

    ws.Cells(2, 5).Value = "Alerta"
    ws.Cells(2, 5).Interior.Color = SonovaOrange()
    ws.Cells(2, 5).Font.Color = vbWhite

    ws.Cells(2, 6).Value = "Neutro"
    ws.Cells(2, 6).Interior.Color = SonovaGray()
    ws.Cells(2, 6).Font.Color = SonovaDarkGray()

    ws.Rows(2).RowHeight = 18
    ws.Rows(3).RowHeight = 8

    ' Cabeçalho fixo (linha 4)
    ws.Cells(4, 1).Value = "Fornecedor"
    ws.Cells(4, 2).Value = "Tipo"
    ws.Cells(4, 3).Value = "Criticidade"
    ws.Cells(4, 4).Value = "Ação"
    ws.Cells(4, 5).Value = "Assunto"
    ws.Cells(4, 6).Value = "Vencimento"
    ws.Cells(4, 7).Value = "Status"

    ws.Range("A4:G4").Font.Bold = True
    ws.Range("A4:G4").Interior.Color = SonovaLightBlue()
    ws.Range("A4:G4").Font.Color = SonovaNavy()
    ws.Rows(4).RowHeight = 20

    ' Semanas em H...
    Dim col As Long
    col = GANTT_FIRST_WEEK_COL

    Dim d As Date
    d = startWeek
    Do While d <= endWeek
        ws.Cells(4, col).Value = "Sem " & Format(d, "dd/mm") & " - " & Format(DateAdd("d", 6, d), "dd/mm")
        ws.Cells(4, col).Font.Bold = True
        ws.Cells(4, col).Interior.Color = SonovaLightBlue()
        ws.Cells(4, col).Font.Color = SonovaNavy()
        ws.Cells(4, col).HorizontalAlignment = -4108
        ws.Columns(col).ColumnWidth = 16
        col = col + 1
        d = DateAdd("d", 7, d)
    Loop

    ' Limpa header antigo à direita (pra lastColWanted ficar correto)
    Dim oldLast As Long
    oldLast = ws.Cells(4, ws.Columns.Count).End(-4159).Column ' xlToLeft
    If oldLast > lastColWanted Then
        ws.Range(ws.Cells(4, lastColWanted + 1), ws.Cells(4, oldLast)).ClearContents
    End If

    ' Larguras colunas fixas
    ws.Columns("A").ColumnWidth = 18
    ws.Columns("B").ColumnWidth = 14
    ws.Columns("C").ColumnWidth = 12
    ws.Columns("D").ColumnWidth = 38
    ws.Columns("E").ColumnWidth = 55
    ws.Columns("F").ColumnWidth = 12
    ws.Columns("G").ColumnWidth = 12

    ' Coluna técnica AA (EntryID)
    On Error Resume Next
    ws.Columns(GANTT_TECH_COL_ENTRYID).Hidden = True
    On Error GoTo 0

End Sub

