' ============================================================
' CORE: PROCESSA 1 E-MAIL (Grava + Checklist + Move)
' ============================================================
Private Sub ProcessarUmMail_Core(ByVal mail As Outlook.MailItem, ByVal wsEmails As Object, ByVal wsChecklist As Object, _
                                ByVal perguntaIndividual As Boolean, ByVal tipoFixo As String, ByVal fornFixo As String)

    On Error GoTo Falha

    Dim linha As Long
    linha = ProximaLinha(wsEmails, "A")

    Dim remetenteEmail As String, remetenteNome As String, assunto As String
    Dim dataEnvio As Variant
    Dim usuarioWindows As String, usuarioOutlook As String
    Dim IDcompleto As String

    Dim valoresTexto As String, valorTotal As Double, temValor As String
    Dim tipo As String, fornecedor As String
    Dim criticidade As String, acaoSug As String
    Dim vencISO As String

    EnsureMoveColsAsText wsEmails

    remetenteEmail = GetSmtpAddress(mail)
    remetenteNome = mail.senderName
    assunto = mail.subject
    dataEnvio = mail.sentOn

    usuarioWindows = Environ$("Username")
    usuarioOutlook = Application.Session.CurrentUser.Name

    IDcompleto = LimparNomeArquivo(mail.entryID)

    valoresTexto = ExtrairValoresReais(mail.Body & vbCrLf & assunto, valorTotal)
    temValor = IIf(valoresTexto <> "", "Sim", "Não")

    vencISO = ExtrairVencimentoISO(mail.Body & vbCrLf & assunto)

    If perguntaIndividual Then
        tipo = PromptTipo(assunto, remetenteEmail)
        fornecedor = PromptFornecedor(assunto, remetenteEmail)
    Else
        tipo = tipoFixo
        fornecedor = fornFixo
    End If

    If Trim$(tipo) = "" Then tipo = "OUTROS"
    If Trim$(fornecedor) = "" Then fornecedor = "N/I"

    criticidade = CriticidadePorTipo(tipo)
    acaoSug = AcaoPorTipo(tipo)

    wsEmails.Cells(linha, 1).Value = dataEnvio
    wsEmails.Cells(linha, 2).Value = remetenteNome
    wsEmails.Cells(linha, 3).Value = remetenteEmail
    wsEmails.Cells(linha, 4).Value = assunto
    wsEmails.Cells(linha, 5).Value = temValor
    wsEmails.Cells(linha, 6).Value = valoresTexto
    wsEmails.Cells(linha, 7).Value = valorTotal
    wsEmails.Cells(linha, 8).Value = IDcompleto
    wsEmails.Cells(linha, 9).Value = usuarioOutlook
    wsEmails.Cells(linha, 10).Value = usuarioWindows
    wsEmails.Cells(linha, 11).Value = fornecedor
    wsEmails.Cells(linha, 12).Value = tipo
    wsEmails.Cells(linha, 13).Value = criticidade
    wsEmails.Cells(linha, 14).Value = vencISO

    wsEmails.Cells(linha, 15).Value = "Recebido"
    wsEmails.Cells(linha, 16).ClearContents
    wsEmails.Cells(linha, 17).ClearContents
    wsEmails.Cells(linha, 18).ClearContents
    wsEmails.Cells(linha, 19).ClearContents

    AppendChecklist wsChecklist, dataEnvio, fornecedor, tipo, criticidade, acaoSug, vencISO, "PENDENTE", remetenteEmail, assunto, IDcompleto

    Dim pastaReg As Outlook.folder
    Set pastaReg = GetTargetFolderSameStore(mail, OUTLOOK_FOLDER_REG)
    If pastaReg Is Nothing Then Err.Raise 70, "MoverEmail", "Não foi possível criar/achar REGISTRADOS no mesmo mailbox."

    mail.Move pastaReg

    wsEmails.Cells(linha, 18).Value = "Movido"
    wsEmails.Cells(linha, 19).Value = "Destino: " & pastaReg.folderPath & " | " & Format(Now, "yyyy-mm-dd hh:nn:ss")
    Exit Sub

Falha:
    On Error Resume Next

    Dim errNum As Long, errDesc As String
    errNum = Err.Number
    errDesc = Err.Description

    Dim pastaFal As Outlook.folder
    Set pastaFal = GetTargetFolderSameStore(mail, OUTLOOK_FOLDER_FAIL)
    If Not pastaFal Is Nothing Then
        mail.Move pastaFal
    End If

    On Error GoTo 0
    On Error Resume Next

    wsEmails.Cells(linha, 18).Value = "Falha"
    wsEmails.Cells(linha, 19).Value = "Erro: " & errNum & " - " & errDesc & " | " & Format(Now, "yyyy-mm-dd hh:nn:ss")
    On Error GoTo 0
End Sub

' ============================================================
' PREVIEW DO LOTE
' ============================================================
Private Function BuildPreviewFromSelection(ByVal sel As Outlook.Selection, ByVal maxItens As Long) As String
    Dim i As Long, c As Long
    Dim obj As Object
    Dim s As String

    s = "Prévia dos primeiros itens:" & vbCrLf

    c = 0
    For i = 1 To sel.Count
        Set obj = sel.Item(i)
        If TypeOf obj Is Outlook.MailItem Then
            c = c + 1
            s = s & " - " & CTypeMail(obj).subject & vbCrLf
            If c >= maxItens Then Exit For
        End If
    Next i

    BuildPreviewFromSelection = s
End Function

