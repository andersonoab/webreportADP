' ============================================================
' CHECKLIST (corrigido: Inicio_ISO pela data do e-mail)
' ============================================================
Private Sub AppendChecklist(ByVal ws As Object, ByVal dtEmail As Variant, ByVal fornecedor As String, ByVal tipo As String, _
                            ByVal criticidade As String, ByVal acao As String, ByVal vencISO As String, ByVal status As String, _
                            ByVal remetente As String, ByVal assunto As String, ByVal entryID As String)

    Dim r As Long
    r = ProximaLinha(ws, "A")

    Dim dtIni As Date
    If IsDate(dtEmail) Then
        dtIni = DateValue(CDate(dtEmail))
    Else
        dtIni = Date
    End If

    Dim dtFim As Date
    If TryParseISODate(vencISO, dtFim) Then
        ' ok
    Else
        dtFim = DateAdd("d", 2, dtIni)
    End If

    ws.Cells(r, 1).Value = dtEmail
    ws.Cells(r, 2).Value = fornecedor
    ws.Cells(r, 3).Value = tipo
    ws.Cells(r, 4).Value = criticidade
    ws.Cells(r, 5).Value = acao
    ws.Cells(r, 6).Value = vencISO
    ws.Cells(r, 7).Value = status

    ws.Cells(r, 8).Value = Format(dtIni, "yyyy-mm-dd")             ' Inicio_ISO (AGORA: data do e-mail)
    ws.Cells(r, 9).Value = Format(dtFim, "yyyy-mm-dd")             ' Fim_ISO

    ws.Cells(r, 10).Value = ""                                     ' Dias
    ws.Cells(r, 11).Value = remetente
    ws.Cells(r, 12).Value = assunto
    ws.Cells(r, 13).Value = entryID
End Sub

' ============================================================
' OUTLOOK: mover para REGISTRADOS/FALHAS (MESMO MAILBOX)
' ============================================================
Private Function GetTargetFolderSameStore(ByVal mail As Outlook.MailItem, ByVal leafFolderName As String) As Outlook.folder
    On Error GoTo Falha

    Dim st As Outlook.Store
    Dim inbox As Outlook.folder
    Dim baseFolder As Outlook.folder
    Dim target As Outlook.folder
    Dim storeId As String

    storeId = mail.Parent.storeId

    For Each st In Application.Session.Stores
        If st.storeId = storeId Then
            Set inbox = st.GetDefaultFolder(olFolderInbox)
            Set baseFolder = GetOrCreateSubFolder(inbox, OUTLOOK_FOLDER_BASE)
            Set target = GetOrCreateSubFolder(baseFolder, leafFolderName)
            Set GetTargetFolderSameStore = target
            Exit Function
        End If
    Next st

    Set GetTargetFolderSameStore = Nothing
    Exit Function

Falha:
    Set GetTargetFolderSameStore = Nothing
End Function

Private Function GetOrCreateSubFolder(ByVal parentFolder As Outlook.folder, ByVal Name As String) As Outlook.folder
    Dim f As Outlook.folder
    On Error Resume Next
    Set f = parentFolder.Folders(Name)
    On Error GoTo 0
    If f Is Nothing Then Set f = parentFolder.Folders.Add(Name)
    Set GetOrCreateSubFolder = f
End Function

