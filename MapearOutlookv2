Private Function LimparNomeArquivo(ByVal s As String) As String
    Dim invalid As String: invalid = "/\:*?""<>|"
    Dim i As Long

    For i = 1 To Len(invalid)
        s = Replace(s, Mid(invalid, i, 1), "_")
    Next i

    s = Replace(s, Chr(160), "_")
    s = Replace(s, Chr(9), "_")
    s = Replace(s, Chr(10), "_")
    s = Replace(s, Chr(13), "_")
    s = Replace(s, ChrW(8203), "_")
    s = Replace(s, ChrW(65279), "_")

    LimparNomeArquivo = Trim$(s)
End Function

