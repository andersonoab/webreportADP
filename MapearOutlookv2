Private Sub ClearWeekCells(ByVal ws As Object, ByVal rowNum As Long, ByVal firstCol As Long, ByVal lastCol As Long)
    If lastCol < firstCol Then Exit Sub
    On Error Resume Next
    ws.Range(ws.Cells(rowNum, firstCol), ws.Cells(rowNum, lastCol)).ClearContents
    ws.Range(ws.Cells(rowNum, firstCol), ws.Cells(rowNum, lastCol)).Interior.Pattern = -4142 ' xlPatternNone
    On Error GoTo 0
End Sub

Private Sub PintarBarrasSemanais(ByVal ws As Object, ByVal outRow As Long, ByVal dtIni As Date, ByVal dtFim As Date, _
                                ByVal startWeek As Date, ByVal endWeek As Date, ByVal lastColWanted As Long)

    Dim iniW As Date, fimW As Date
    iniW = WeekStartMonday(dtIni)
    fimW = WeekStartMonday(dtFim)

    If fimW < startWeek Then Exit Sub
    If iniW > endWeek Then Exit Sub

    Dim colStart As Long, colEnd As Long
    colStart = GANTT_FIRST_WEEK_COL + CLng((iniW - startWeek) / 7)
    colEnd = GANTT_FIRST_WEEK_COL + CLng((fimW - startWeek) / 7)

    If colStart < GANTT_FIRST_WEEK_COL Then colStart = GANTT_FIRST_WEEK_COL
    If colEnd < GANTT_FIRST_WEEK_COL Then colEnd = GANTT_FIRST_WEEK_COL
    If colStart > lastColWanted Then Exit Sub
    If colEnd > lastColWanted Then colEnd = lastColWanted
    If colEnd < colStart Then colEnd = colStart

    Dim c As Long
    For c = colStart To colEnd
        ws.Cells(outRow, c).Value = 1
        ws.Cells(outRow, c).NumberFormat = ";;;"
    Next c

End Sub

Private Sub FinalizarGanttLayout(ByVal ws As Object, ByVal lastDataRow As Long, ByVal lastCol As Long)

    If lastDataRow < GANTT_FIRST_DATA_ROW Then lastDataRow = GANTT_FIRST_DATA_ROW

    With ws.Range(ws.Cells(4, 1), ws.Cells(lastDataRow, lastCol)).Borders
        .LineStyle = 1
        .Color = RGB(220, 220, 220)
        .Weight = 2
    End With

    ws.Range(ws.Cells(GANTT_FIRST_DATA_ROW, GANTT_FIRST_WEEK_COL), ws.Cells(lastDataRow, lastCol)).HorizontalAlignment = -4108
    ws.Range(ws.Cells(GANTT_FIRST_DATA_ROW, GANTT_FIRST_WEEK_COL), ws.Cells(lastDataRow, lastCol)).VerticalAlignment = -4108

    ws.Range(ws.Cells(GANTT_FIRST_DATA_ROW, 1), ws.Cells(lastDataRow, 7)).VerticalAlignment = -4160
    ws.Range(ws.Cells(GANTT_FIRST_DATA_ROW, 4), ws.Cells(lastDataRow, 5)).WrapText = True

    ws.Rows(GANTT_FIRST_DATA_ROW & ":" & lastDataRow).RowHeight = 15

    AplicarFormatacaoCondicionalGantt ws, lastDataRow, lastCol
    AplicarFormatacaoCondicionalColunaF_Vencimento ws, lastDataRow

