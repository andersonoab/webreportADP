        Case "BENEFICIOS": CriticidadePorTipo = "ALTA"
        Case "NF": CriticidadePorTipo = "ALTA"
        Case "FORNECEDORES": CriticidadePorTipo = "MEDIA"
        Case "FOLHA": CriticidadePorTipo = "ALTA"
