' ============================================================
' DATA ISO yyyy-mm-dd (extrai dd/mm/aaaa ou dd/mm/aa)
' ============================================================
Private Function ExtrairVencimentoISO(ByVal texto As String) As String
    Dim re As Object, ms As Object, m As Object
    Dim s As String
    Dim dd As Integer, mm As Integer, yy As Integer
    Dim parts() As String

    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.IgnoreCase = True
    re.Pattern = "(\b[0-3]?\d/[01]?\d/(\d{2}|\d{4})\b)"

    If Not re.Test(texto) Then
        ExtrairVencimentoISO = ""
        Exit Function
    End If

    Set ms = re.Execute(texto)
    Set m = ms(0)
    s = m.Value

    parts = Split(s, "/")
    If UBound(parts) <> 2 Then
        ExtrairVencimentoISO = ""
        Exit Function
    End If

    dd = CInt(parts(0))
    mm = CInt(parts(1))
    yy = CInt(parts(2))
    If yy < 100 Then yy = 2000 + yy

    On Error Resume Next
    ExtrairVencimentoISO = Format(DateSerial(yy, mm, dd), "yyyy-mm-dd")
    If Err.Number <> 0 Then
        Err.Clear
        ExtrairVencimentoISO = ""
    End If
    On Error GoTo 0
End Function

