Public Sub AtualizarGantt(ByVal wb As Object, ByVal wsChecklist As Object)
    On Error GoTo TrataErro

    Dim wsGantt As Object
    Set wsGantt = EnsureSheet(wb, GANTT_SHEET_NAME)

    MontarGantt_FromChecklist wsChecklist, wsGantt

    Exit Sub
TrataErro:
    Debug.Print "AtualizarGantt erro " & Err.Number & ": " & Err.Description
End Sub

Private Sub MontarGantt_FromChecklist(ByVal wsChecklist As Object, ByVal wsGantt As Object)
    On Error GoTo TrataErro

    Dim lastRow As Long
    lastRow = wsChecklist.Cells(wsChecklist.Rows.Count, "A").End(-4162).Row
    If lastRow < 2 Then
        PrepararLayoutGanttVazio wsGantt
        Exit Sub
    End If

    Dim r As Long
    Dim dtIni As Date, dtFim As Date
    Dim dtMin As Date, dtMax As Date
    Dim haveDate As Boolean

    haveDate = False
    For r = 2 To lastRow
        If TryParseISODate(wsChecklist.Cells(r, 8).Value, dtIni) Then
            If Not haveDate Then
                dtMin = dtIni: dtMax = dtIni: haveDate = True
            Else
                If dtIni < dtMin Then dtMin = dtIni
                If dtIni > dtMax Then dtMax = dtIni
            End If
        End If

        If TryParseISODate(wsChecklist.Cells(r, 9).Value, dtFim) Then
            If Not haveDate Then
                dtMin = dtFim: dtMax = dtFim: haveDate = True
            Else
                If dtFim < dtMin Then dtMin = dtFim
                If dtFim > dtMax Then dtMax = dtFim
            End If
        End If
    Next r

    If Not haveDate Then
        dtMin = Date
        dtMax = Date + 28
    End If

    Dim startWeek As Date, endWeek As Date
    startWeek = WeekStartMonday(dtMin)
    endWeek = WeekStartMonday(dtMax)

    If endWeek < startWeek + (7 * 7) Then endWeek = startWeek + (7 * 7)

    wsGantt.Cells.Clear
    MontarCabecalhoGantt wsGantt, startWeek, endWeek

    Dim outRow As Long
    outRow = 5

    For r = 2 To lastRow

        Dim fornecedor As String, tipo As String, criticidade As String, acao As String
        Dim vencISO As String, status As String, assunto As String

        fornecedor = CStr(wsChecklist.Cells(r, 2).Value)
        tipo = CStr(wsChecklist.Cells(r, 3).Value)
        criticidade = CStr(wsChecklist.Cells(r, 4).Value)
        acao = CStr(wsChecklist.Cells(r, 5).Value)
        vencISO = CStr(wsChecklist.Cells(r, 6).Value)
        status = CStr(wsChecklist.Cells(r, 7).Value)
        assunto = CStr(wsChecklist.Cells(r, 12).Value)

        If Not TryParseISODate(wsChecklist.Cells(r, 8).Value, dtIni) Then dtIni = startWeek
        If Not TryParseISODate(wsChecklist.Cells(r, 9).Value, dtFim) Then
            If TryParseISODate(vencISO, dtFim) Then
            Else
                dtFim = dtIni + 7
            End If
        End If
        If dtFim < dtIni Then dtFim = dtIni

        ' Colunas fixas (A..G)
        wsGantt.Cells(outRow, 1).Value = fornecedor
        wsGantt.Cells(outRow, 2).Value = tipo
        wsGantt.Cells(outRow, 3).Value = criticidade
        wsGantt.Cells(outRow, 4).Value = acao
        wsGantt.Cells(outRow, 5).Value = assunto

        Dim dtVenc As Date
        If TryParseISODate(vencISO, dtVenc) Then
            wsGantt.Cells(outRow, 6).NumberFormat = "dd/mm/yyyy"
            wsGantt.Cells(outRow, 6).Value = dtVenc
        Else
            wsGantt.Cells(outRow, 6).NumberFormat = "@"
            wsGantt.Cells(outRow, 6).Value = vencISO
        End If

        wsGantt.Cells(outRow, 7).Value = status

        ' Semanas começam em H (8)
        PintarBarrasSemanais wsGantt, outRow, dtIni, dtFim, startWeek, status, criticidade, vencISO

        outRow = outRow + 1
    Next r

    FinalizarGanttLayout wsGantt, outRow - 1

    Exit Sub

TrataErro:
    Debug.Print "MontarGantt_FromChecklist erro " & Err.Number & ": " & Err.Description
End Sub

