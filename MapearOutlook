Private Sub MontarCabecalhoGantt(ByVal ws As Object, ByVal startWeek As Date, ByVal endWeek As Date)

    ws.Range("A1").Value = "GANTT - DP Triagem (por semana)"
    ws.Range("A1:G1").Merge
    ws.Range("A1").Font.Bold = True
    ws.Range("A1").Font.Size = 14
    ws.Range("A1").Interior.Color = SonovaNavy()
    ws.Range("A1").Font.Color = vbWhite
    ws.Rows(1).RowHeight = 26

    ws.Range("A2").Value = "Legenda:"
    ws.Range("A2").Font.Bold = True

    ws.Range("B2").Value = "Concluído"
    ws.Range("B2").Interior.Color = SonovaGreen()
    ws.Range("B2").Font.Color = vbWhite

    ws.Range("C2").Value = "Pendente"
    ws.Range("C2").Interior.Color = SonovaBlue()
    ws.Range("C2").Font.Color = vbWhite

    ws.Range("D2").Value = "Atrasado"
    ws.Range("D2").Interior.Color = SonovaRed()
    ws.Range("D2").Font.Color = vbWhite

    ws.Range("E2").Value = "Alerta"
    ws.Range("E2").Interior.Color = SonovaOrange()
    ws.Range("E2").Font.Color = vbWhite

    ws.Range("F2").Value = "Neutro"
    ws.Range("F2").Interior.Color = SonovaGray()
    ws.Range("F2").Font.Color = SonovaDarkGray()

    ws.Rows(2).RowHeight = 18

    ' Cabeçalho fixo (linha 4)
    ws.Range("A4").Value = "Fornecedor"
    ws.Range("B4").Value = "Tipo"
    ws.Range("C4").Value = "Criticidade"
    ws.Range("D4").Value = "Ação"
    ws.Range("E4").Value = "Assunto"
    ws.Range("F4").Value = "Vencimento"
    ws.Range("G4").Value = "Status"

    ws.Range("A4:G4").Font.Bold = True
    ws.Range("A4:G4").Interior.Color = SonovaLightBlue()
    ws.Range("A4:G4").Font.Color = SonovaNavy()
    ws.Rows(4).RowHeight = 20

    Dim col As Long
    col = 8 ' semanas começam em H

    Dim d As Date
    d = startWeek
    Do While d <= endWeek
        ws.Cells(4, col).Value = "Sem " & Format(d, "dd/mm") & " - " & Format(d + 6, "dd/mm")
        ws.Cells(4, col).Font.Bold = True
        ws.Cells(4, col).Interior.Color = SonovaLightBlue()
        ws.Cells(4, col).Font.Color = SonovaNavy()
        ws.Cells(4, col).HorizontalAlignment = -4108
        ws.Columns(col).ColumnWidth = 16
        col = col + 1
        d = d + 7
    Loop

    ' Larguras colunas fixas
    ws.Columns("A").ColumnWidth = 18
    ws.Columns("B").ColumnWidth = 14
    ws.Columns("C").ColumnWidth = 12
    ws.Columns("D").ColumnWidth = 38
    ws.Columns("E").ColumnWidth = 55
    ws.Columns("F").ColumnWidth = 12
    ws.Columns("G").ColumnWidth = 12
End Sub

Private Sub PintarBarrasSemanais(ByVal ws As Object, ByVal outRow As Long, ByVal dtIni As Date, ByVal dtFim As Date, _
                                ByVal startWeek As Date, ByVal status As String, ByVal criticidade As String, ByVal vencISO As String)

    Dim cor As Long
    cor = CorPorStatusECriticidade(status, criticidade, vencISO)

    Dim colStart As Long, colEnd As Long
    colStart = 8 + CLng((WeekStartMonday(dtIni) - startWeek) / 7)
    colEnd = 8 + CLng((WeekStartMonday(dtFim) - startWeek) / 7)

    If colStart < 8 Then colStart = 8
    If colEnd < 8 Then colEnd = 8
    If colEnd < colStart Then colEnd = colStart

    Dim c As Long
    For c = colStart To colEnd
        ws.Cells(outRow, c).Interior.Color = cor
        ws.Cells(outRow, c).Value = 1          ' IMPORTANTE p/ formatação condicional
        ws.Cells(outRow, c).NumberFormat = ";;;" ' esconde o 1
    Next c

    If (outRow Mod 2) = 0 Then
        Dim lastCol As Long
        lastCol = ws.Cells(4, ws.Columns.Count).End(-4159).Column

        ws.Range(ws.Cells(outRow, 1), ws.Cells(outRow, lastCol)).Interior.Color = RGB(255, 255, 255)

        For c = colStart To colEnd
            ws.Cells(outRow, c).Interior.Color = cor
            ws.Cells(outRow, c).Value = 1
            ws.Cells(outRow, c).NumberFormat = ";;;"
        Next c
    End If
End Sub

Private Function CorPorStatusECriticidade(ByVal status As String, ByVal criticidade As String, ByVal vencISO As String) As Long

    Dim st As String
    st = UCase$(Trim$(status))
    If st = "" Then st = "PENDENTE"

    Dim dtVenc As Date
    Dim hasVenc As Boolean
    hasVenc = TryParseISODate(vencISO, dtVenc)

    If hasVenc Then
        If Date > dtVenc Then
            If InStr(1, st, "CONCL", vbTextCompare) = 0 And InStr(1, st, "PAGO", vbTextCompare) = 0 And InStr(1, st, "OK", vbTextCompare) = 0 Then
                st = "ATRASADO"
            End If
        End If
    End If

    Select Case True
        Case (InStr(1, st, "CONCL", vbTextCompare) > 0) Or (InStr(1, st, "PAGO", vbTextCompare) > 0) Or (InStr(1, st, "OK", vbTextCompare) > 0)
            CorPorStatusECriticidade = SonovaGreen()

        Case (InStr(1, st, "ATRAS", vbTextCompare) > 0) Or (InStr(1, st, "VENC", vbTextCompare) > 0)
            CorPorStatusECriticidade = SonovaRed()

        Case UCase$(Trim$(criticidade)) = "ALTA"
            CorPorStatusECriticidade = SonovaOrange()

        Case (InStr(1, st, "PEND", vbTextCompare) > 0) Or (InStr(1, st, "EM AND", vbTextCompare) > 0)
            CorPorStatusECriticidade = SonovaBlue()

        Case Else
            CorPorStatusECriticidade = SonovaGray()
    End Select
End Function

Private Sub FinalizarGanttLayout(ByVal ws As Object, ByVal lastDataRow As Long)

    Dim lastCol As Long
    lastCol = ws.Cells(4, ws.Columns.Count).End(-4159).Column
    If lastDataRow < 5 Then lastDataRow = 5

    With ws.Range(ws.Cells(4, 1), ws.Cells(lastDataRow, lastCol)).Borders
        .LineStyle = 1
        .Color = RGB(220, 220, 220)
        .Weight = 2
    End With

    ' Semanas (H..)
    ws.Range(ws.Cells(5, 8), ws.Cells(lastDataRow, lastCol)).HorizontalAlignment = -4108
    ws.Range(ws.Cells(5, 8), ws.Cells(lastDataRow, lastCol)).VerticalAlignment = -4108

    ' Fixas (A..G)
    ws.Range(ws.Cells(5, 1), ws.Cells(lastDataRow, 7)).VerticalAlignment = -4160
    ws.Range(ws.Cells(5, 4), ws.Cells(lastDataRow, 5)).WrapText = True ' ação + assunto

    ws.Activate
    ws.Range("H5").Select
    On Error Resume Next
    ActiveWindow.FreezePanes = False
    ActiveWindow.FreezePanes = True
    On Error GoTo 0

    ws.Rows(3).RowHeight = 8
    ws.Rows("5:" & lastDataRow).RowHeight = 15
    ws.Range("A1").Select

    ' APLICA FORMATAÇÃO CONDICIONAL INTERNA (dinâmica com HOJE())
    AplicarFormatacaoCondicionalGantt ws, lastDataRow, lastCol

End Sub

Private Function WeekStartMonday(ByVal d As Date) As Date
    WeekStartMonday = d - (Weekday(d, vbMonday) - 1)
End Function

Private Function TryParseISODate(ByVal v As Variant, ByRef outDate As Date) As Boolean
    On Error GoTo Falha

    Dim s As String
    s = Trim$(CStr(v))
    If s = "" Then
        TryParseISODate = False
        Exit Function
    End If

    If Len(s) >= 10 Then
        Dim yy As Integer, mm As Integer, dd As Integer
        yy = CInt(Mid$(s, 1, 4))
        mm = CInt(Mid$(s, 6, 2))
        dd = CInt(Mid$(s, 9, 2))
        outDate = DateSerial(yy, mm, dd)
        TryParseISODate = True
        Exit Function
    End If

Falha:
    TryParseISODate = False
End Function

' ============================================================
' FORMATAÇÃO CONDICIONAL DO GANTT (sem "Range As Range" etc.)
' Objetivo: manter cor dinâmica (ex.: 3 dias antes do vencimento)
' ============================================================
Private Sub AplicarFormatacaoCondicionalGantt(ByVal ws As Object, ByVal lastRow As Long, ByVal lastCol As Long)

    On Error GoTo TrataErro

    If lastRow < 5 Then Exit Sub
    If lastCol < 8 Then Exit Sub

    Dim rng As Object
    Set rng = ws.Range(ws.Cells(5, 8), ws.Cells(lastRow, lastCol)) ' H5..última

    ' Apaga regras antigas
    rng.FormatConditions.Delete

    ' Esconde o "1" (barra) caso alguma célula fique visível
    rng.NumberFormat = ";;;"

    Dim fc As Object

    ' 1) Concluído (prioridade máxima)
    Set fc = rng.FormatConditions.Add(Type:=2, Formula1:="=1=1")
    fc.FormulaLocal = "=(H5=1)*OU($G5=""CONCLUIDO"";$G5=""CONCLUÍDO"";$G5=""PAGO"";$G5=""OK"")"
    fc.Interior.Color = SonovaGreen()
    fc.StopIfTrue = True

    ' 2) Atrasado (HOJE > vencimento) e não concluído
    Set fc = rng.FormatConditions.Add(Type:=2, Formula1:="=1=1")
    fc.FormulaLocal = "=(H5=1)*E(ÉNÚM($F5);HOJE()>$F5;NÃO(OU($G5=""CONCLUIDO"";$G5=""CONCLUÍDO"";$G5=""PAGO"";$G5=""OK"")))"
    fc.Interior.Color = SonovaRed()
    fc.StopIfTrue = True

    ' 3) Alerta (3 dias antes até o vencimento) e não concluído
    Set fc = rng.FormatConditions.Add(Type:=2, Formula1:="=1=1")
    fc.FormulaLocal = "=(H5=1)*E(ÉNÚM($F5);HOJE()>=$F5-3;HOJE()<=$F5;NÃO(OU($G5=""CONCLUIDO"";$G5=""CONCLUÍDO"";$G5=""PAGO"";$G5=""OK"")))"
    fc.Interior.Color = SonovaOrange()
    fc.StopIfTrue = True

    ' 4) Pendente (tem barra e não caiu nas regras acima)
    Set fc = rng.FormatConditions.Add(Type:=2, Formula1:="=1=1")
    fc.FormulaLocal = "=(H5=1)*OU(ÉCÉL.VAZIA($G5);$G5=""PENDENTE"";$G5=""EM ANDAMENTO"";$G5=""EM AND"";$G5=""EM ANDAM"")"
    fc.Interior.Color = SonovaBlue()
    fc.StopIfTrue = True

    ' 5) Neutro (fallback: só onde há barra)
    Set fc = rng.FormatConditions.Add(Type:=2, Formula1:="=1=1")
    fc.FormulaLocal = "=(H5=1)"
    fc.Interior.Color = SonovaGray()
    fc.StopIfTrue = True

    Exit Sub

TrataErro:
    Debug.Print "AplicarFormatacaoCondicionalGantt erro " & Err.Number & ": " & Err.Description
End Sub

