' ============================================================
' ENTRADA PRINCIPAL
' ============================================================
Public Sub aayMapearEmails_DP()

    On Error GoTo TrataErro

    Dim exp As Outlook.Explorer
    Dim sel As Outlook.Selection
    Dim folder As Outlook.folder

    Set exp = Application.ActiveExplorer
    If Not exp Is Nothing Then
        Set sel = exp.Selection
        Set folder = exp.CurrentFolder
    End If

    ' 1) Se tem seleção: perguntar se é massivo ou individual
    If Not sel Is Nothing Then
        If sel.Count > 0 Then
            Dim modo As VbMsgBoxResult
            modo = MsgBox( _
                "Você selecionou " & sel.Count & " e-mail(s)." & vbCrLf & vbCrLf & _
                "Sim = Classificar em lote (mesmo Tipo/Fornecedor para todos)" & vbCrLf & _
                "Não = Classificar individualmente (pergunta Tipo/Fornecedor para cada e-mail)", _
                vbYesNo + vbQuestion, "Modo de classificação")

            If modo = vbYes Then
                ProcessarSelecao_Massivo sel
            Else
                ProcessarSelecao_Individual sel
            End If

            MsgBox "Concluído.", vbInformation
            Exit Sub
        End If
    End If

    ' 2) Se não tem seleção -> tenta e-mail aberto
    Dim insp As Outlook.Inspector
    Dim currentItem As Object

    Set insp = Application.ActiveInspector
    If Not insp Is Nothing Then
        Set currentItem = insp.currentItem
        If Not currentItem Is Nothing Then
            If TypeOf currentItem Is Outlook.MailItem Then
                If MsgBox("Não há seleção. Deseja mapear o e-mail aberto agora?", vbYesNo + vbQuestion, "Mapear e-mail aberto") = vbYes Then
                    ProcessarUmMail_Individual CTypeMail(currentItem)
                    MsgBox "Concluído.", vbInformation
                    Exit Sub
                End If
            End If
        End If
    End If

    ' 3) Se não tem seleção nem e-mail aberto -> pergunta se quer mapear todos da pasta atual (individual)
    If folder Is Nothing Then
        MsgBox "Não identifiquei a pasta atual no Outlook.", vbCritical
        Exit Sub
    End If

    Dim resp As VbMsgBoxResult
    resp = MsgBox("Nenhum e-mail selecionado." & vbCrLf & _
                  "Deseja mapear TODOS os e-mails da pasta atual?" & vbCrLf & vbCrLf & _
                  "Pasta: " & folder.folderPath & vbCrLf & vbCrLf & _
                  "Atenção: este modo pergunta Tipo/Fornecedor para cada e-mail.", _
                  vbYesNo + vbQuestion, "Mapear todos da pasta")

    If resp = vbYes Then
        ProcessarPastaCompleta_Individual folder
        MsgBox "Concluído.", vbInformation
    Else
        MsgBox "Operação cancelada.", vbInformation
    End If

    Exit Sub

TrataErro:
    MsgBox "Erro " & Err.Number & ": " & Err.Description, vbCritical
End Sub

' ============================================================
' MASSIVO: SELEÇÃO
' ============================================================
Private Sub ProcessarSelecao_Massivo(ByVal sel As Outlook.Selection)

    On Error GoTo TrataErro

    Dim xlApp As Object, xlWb As Object
    Dim wsEmails As Object, wsChecklist As Object, wsDom As Object
    Dim excelCriado As Boolean

    Set xlApp = GetExcelApp(excelCriado)
    xlApp.Visible = False
    xlApp.DisplayAlerts = False

    Set xlWb = xlApp.Workbooks.Open(CAMINHO_EXCEL)

    Set wsEmails = EnsureSheet(xlWb, "EMAILS")
    Set wsChecklist = EnsureSheet(xlWb, "CHECKLIST")
    Set wsDom = EnsureSheet(xlWb, "DOMINIOS")

    EnsureHeadersEmails wsEmails
    EnsureHeadersChecklist wsChecklist
    EnsureHeadersDominios wsDom

    Dim preview As String
    preview = BuildPreviewFromSelection(sel, 15)

    Dim tipo As String, fornecedor As String
    tipo = PromptTipo("LOTE", "Seleção (" & sel.Count & " e-mails)" & vbCrLf & vbCrLf & preview)
    fornecedor = PromptFornecedor("LOTE", "Seleção (" & sel.Count & " e-mails)" & vbCrLf & vbCrLf & preview)

    If Trim$(tipo) = "" Then tipo = "OUTROS"
    If Trim$(fornecedor) = "" Then fornecedor = "N/I"

    Dim obj As Object
    For Each obj In sel
        If TypeOf obj Is Outlook.MailItem Then
            ProcessarUmMail_Massivo CTypeMail(obj), wsEmails, wsChecklist, tipo, fornecedor
            DoEvents
        End If
    Next obj

Saida:
    On Error Resume Next
    AtualizarGantt xlWb, wsChecklist
    xlWb.Save
    xlWb.Close False
    If excelCriado Then xlApp.Quit
    Exit Sub

TrataErro:
    MsgBox "Erro " & Err.Number & ": " & Err.Description, vbCritical
    Resume Saida
End Sub

