' ============================================================
' EXTRAI VALORES
' ============================================================
Private Function ExtrairValoresReais(ByVal texto As String, ByRef soma As Double) As String
    Dim regex As Object, matches As Object, m As Object
    Dim lista As String
    Dim strVal As String, numVal As Double

    soma = 0
    lista = ""

    Set regex = CreateObject("VBScript.RegExp")
    regex.Global = True
    regex.IgnoreCase = True
    regex.Pattern = "([0-9]{1,3}(\.[0-9]{3})*|[0-9]+),[0-9]{2}"

    If Not regex.Test(texto) Then
        ExtrairValoresReais = ""
        Exit Function
    End If

    Set matches = regex.Execute(texto)

    For Each m In matches
        strVal = m.Value
        If lista = "" Then lista = strVal Else lista = lista & "; " & strVal

        strVal = Replace(strVal, ".", "")
        strVal = Replace(strVal, ",", ".")

        If IsNumeric(strVal) Then
            numVal = CDbl(strVal)
            soma = soma + numVal
        End If
    Next m

    ExtrairValoresReais = lista
End Function

